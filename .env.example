# ============================================================
#  BRO CARS — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to Git.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Email Provider ───────────────────────────────────────────
# Options: gmail | outlook | smtp
EMAIL_PROVIDER=gmail

# ── Gmail Setup ──────────────────────────────────────────────
# 1. Go to myaccount.google.com → Security → 2-Step Verification (enable it)
# 2. Then: myaccount.google.com → Security → App Passwords
# 3. Generate a 16-char password for "Mail" and paste below
EMAIL_USER=shimla85@gmail.com
EMAIL_PASS=abcd efgh ijkl mnop

# ── Where to receive enquiries ────────────────────────────────
EMAIL_TO=shimla85@gmail.com

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://brocars.lk,https://www.brocars.lk
ALLOWED_ORIGINS=https://brocars.lk,https://www.brocars.lk

# ── Generic SMTP (only needed if EMAIL_PROVIDER=smtp) ─────────
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=false
